# ========== SERVIDOR ==========
PORT=3000
NODE_ENV=development
DRAFTS_DIR=./storage/drafts
PREFERENCES_DIR=./storage/preferences

# ========== FEDEX API ==========
FEDEX_API_KEY=your_fedex_api_key
FEDEX_SECRET_KEY=your_fedex_secret_key
FEDEX_ACCOUNT_NUMBER=your_fedex_account_number
FEDEX_BASE_URL=https://apis.fedex.com

# ========== FEDEX SHIPPER (PARA PROCESSAMENTO DE PEDIDOS) ==========
FEDEX_SHIPPER_CONTACT_NAME=Warehouse Team
FEDEX_SHIPPER_COMPANY_NAME=FedEx PSDU App
FEDEX_SHIPPER_PHONE=5511999999999
FEDEX_SHIPPER_EMAIL=warehouse@example.com
FEDEX_SHIPPER_ADDRESS_LINE1=Rua Exemplo 123
FEDEX_SHIPPER_ADDRESS_LINE2=Sala 4
FEDEX_SHIPPER_CITY=Sao Paulo
FEDEX_SHIPPER_STATE=SP
FEDEX_SHIPPER_POSTAL_CODE=01001000
FEDEX_SHIPPER_COUNTRY_CODE=BR

# ========== SHOPIFY API (OPCIONAL) ==========
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_PASSWORD=your_shopify_api_password
SHOPIFY_SHOP_NAME=your-shop-name

ALLOWED_ORIGIN=https://www.fedex.com
